{
  "name": "hemusic",
  "productName": "HE-Music",
  "version": "1.0.0",
  "description": "A minimalist music player",
  "main": "./out/main/index.js",
  "author": "serious-snow",
  "home": "https://wjhe.top",
  "github": "https://github.com/serious-snow/HE-Music",
  "blog": "https://blog.wjhe.top",
  "repository": "github:serious-snow/HE-Music",
  "license": "AGPL-3.0",
  "license-file": "LICENSE",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "lint": "npx eslint . --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "node scripts/dev.mjs",
    "build": "npx rimraf dist && npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:web": "npm run build",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win --config electron-builder.config.ts",
    "build:mac": "npm run build && electron-builder --mac --config electron-builder.config.ts",
    "build:linux": "npm run build && electron-builder --linux --config electron-builder.config.ts"
  },
  "dependencies": {
    "@applemusic-like-lyrics/core": "^0.1.3",
    "@applemusic-like-lyrics/lyric": "^0.2.4",
    "@applemusic-like-lyrics/vue": "^0.1.5",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@imsyy/color-utils": "^1.0.2",
    "@material/material-color-utilities": "^0.3.0",
    "@neteasecloudmusicapienhanced/api": "^4.29.16",
    "@pixi/app": "^7.4.3",
    "@pixi/core": "^7.4.3",
    "@pixi/display": "^7.4.3",
    "@pixi/filter-blur": "^7.4.3",
    "@pixi/filter-bulge-pinch": "^5.1.1",
    "@pixi/filter-color-matrix": "^7.4.3",
    "@pixi/sprite": "^7.4.3",
    "@vueuse/core": "^13.7.0",
    "axios": "^1.11.0",
    "change-case": "^5.4.4",
    "dayjs": "^1.11.13",
    "electron-dl": "^4.0.0",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.6.2",
    "file-saver": "^2.0.5",
    "font-list": "^1.5.1",
    "get-port": "^7.1.0",
    "github-markdown-css": "^5.8.1",
    "go-captcha-vue": "^2.0.6",
    "hls.js": "^1.6.10",
    "howler": "^2.2.4",
    "i18next": "^25.3.6",
    "js-cookie": "^3.0.5",
    "jss": "^10.10.0",
    "jss-preset-default": "^10.10.0",
    "localforage": "^1.10.0",
    "lodash-es": "^4.17.21",
    "marked": "^16.2.0",
    "md5": "^2.3.0",
    "pinia": "^3.0.3",
    "pinia-plugin-persistedstate": "^4.5.0",
    "plyr": "^3.7.8",
    "vue-dompurify-html": "^5.3.0",
    "vue-i18n": "^11.1.11",
    "vue-virt-list": "^1.5.11"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/http-proxy": "^11.3.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.2.0",
    "@types/file-saver": "^2.0.7",
    "@types/howler": "^2.2.12",
    "@types/js-cookie": "^3.0.6",
    "@types/md5": "^2.3.5",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "ajv": "^8.17.1",
    "crypto-js": "^4.2.0",
    "electron": "^37.6.0",
    "electron-builder": "^26.0.12",
    "electron-log": "^5.4.3",
    "electron-vite": "^4.0.0",
    "eslint": "^9.33.0",
    "eslint-plugin-vue": "^10.4.0",
    "fast-glob": "^3.3.3",
    "fastify": "^5.5.0",
    "naive-ui": "^2.42.0",
    "node-taglib-sharp": "^6.0.1",
    "prettier": "^3.6.2",
    "sass": "^1.90.0",
    "terser": "^5.43.1",
    "typescript": "5.9.2",
    "unplugin-auto-import": "^20.0.0",
    "unplugin-vue-components": "^29.0.0",
    "vite": "^7.1.3",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-wasm": "^3.5.0",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1",
    "vue-tsc": "3.0.5"
  },
  "pnpm": {
    "overrides": {
      "dmg-builder": "26.0.12",
      "electron-builder-squirrel-windows": "26.0.12"
    },
    "onlyBuiltDependencies": [
      "@applemusic-like-lyrics/lyric",
      "@parcel/watcher",
      "core-js",
      "electron",
      "electron-winstaller",
      "esbuild",
      "sharp",
      "vue-demi"
    ]
  }
}
